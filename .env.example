# -----------------------------------------------------------------------------
# Copy this file to `.env.local` in the SAME folder as `package.json`, then fill
# in values. Never commit `.env.local` (it is listed in `.gitignore` lines 4-5).
# -----------------------------------------------------------------------------

# --- Anthropic (Claude): companion chat + entry analysis --------------------
# Get: https://console.anthropic.com/ → Account → API keys → Create Key
ANTHROPIC_API_KEY=

# --- Google OAuth (NextAuth “Sign in with Google”) ---------------------------
# Get: https://console.cloud.google.com/ → your project → APIs & Services →
# Credentials → Create credentials → OAuth client ID → Application type: Web
# Authorized JavaScript origins: http://localhost:3001
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
# Also enable “Google Drive API” for the project, and under OAuth consent screen
# add the non-sensitive scope: ../auth/drive.appdata (private app folder backup).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth session encryption --------------------------------------------
# Generate locally, e.g. PowerShell:  [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
# Or:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# --- Canonical site URL (must match how you open the app in the browser) ---
# Local dev (this repo runs Next on port 3001; see package.json "dev" script):
NEXTAUTH_URL=http://localhost:3001

# --- Optional: OpenAI (Whisper) for server-side audio transcription ----------
OPENAI_API_KEY=

# --- Optional: Resend (email “nudge now” button) -----------------------------
# Get: https://resend.com/ → API Keys. For testing, Resend may restrict "from";
# set EMAIL_FROM to what Resend allows for your account (dashboard will show).
RESEND_API_KEY=
EMAIL_FROM=
